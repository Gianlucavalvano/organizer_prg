# Production-like environment (docker/vps)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=organizer_db
DB_USER=organizer_user
DB_PASSWORD=organizer_pass

API_SECRET_KEY=CHANGE_ME_IN_PROD
API_ACCESS_TOKEN_MINUTES=120

# Frontend container -> backend container URL
API_BASE_URL=http://backend:8000

# Optional bootstrap admin at backend startup
BOOTSTRAP_ADMIN_USERNAME=admin4
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_ADMIN
